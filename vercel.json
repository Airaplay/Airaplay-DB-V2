{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/share/song/(.*)",
      "dest": "/api/share/song/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_APP_TARGET": "web"
  }
}


