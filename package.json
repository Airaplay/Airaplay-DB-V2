{
  "name": "music-streaming-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "VITE_APP_TARGET=web vite",
    "dev:app": "VITE_APP_TARGET=app vite",
    "build": "tsc --incremental && vite build",
    "build:web": "VITE_APP_TARGET=web tsc --incremental && vite build",
    "build:app": "VITE_APP_TARGET=app tsc --incremental && vite build",
    "clean-build": "rm -rf dist && tsc --incremental && vite build",
    "clean-build:web": "rm -rf dist && VITE_APP_TARGET=web tsc --incremental && vite build",
    "clean-build:app": "rm -rf dist && VITE_APP_TARGET=app tsc --incremental && vite build",
    "lint": "eslint src supabase/functions --max-warnings 0",
    "lint:fix": "eslint src supabase/functions --fix",
    "preview": "vite preview",
    "postinstall": "node scripts/apply-admob-staging-banner.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.0.3",
    "@capacitor-community/media": "^9.0.1",
