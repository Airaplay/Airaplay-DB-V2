    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.4.32",
    "supabase": "^2.63.1",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.2",
