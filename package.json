    "@radix-ui/react-tabs": "^1.1.1",
    "@supabase/supabase-js": "^2.39.3",
    "@types/node": "^20.11.5",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "embla-carousel-autoplay": "^8.0.0",
    "embla-carousel-react": "^8.0.0",
    "hls.js": "^1.6.14",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
