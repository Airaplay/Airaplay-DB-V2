    "@capacitor/browser": "^7.0.3",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/share": "^8.0.0",
    "@capacitor/splash-screen": "^7.0.4",
    "@capacitor/status-bar": "^7.0.5",
    "@capgo/capacitor-media-session": "^8.0.14",
